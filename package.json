{
  "name": "neatmark",
  "description": "A Notion-inspired bookmark manager.",
  "version": "2.0.0",
  "license": "MIT",
  "homepage": "https://github.com/Neatmark-io/neatmark",
  "author": "Oleg Shulyakov (https://github.com/olegshulyakov/)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite dev",
    "build": "vite build",
    "build:github": "vite build --base=/neatmark && cp README.md dist/README.md",
    "lint": "eslint . && svelte-check --tsconfig ./tsconfig.json",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "bits-ui": "^2.18.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/css": "^1.2.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@vite-pwa/sveltekit": "^1.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-csstree": "^0.3.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Neatmark-io/neatmark.git"
  }
}
